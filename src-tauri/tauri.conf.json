{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "千古名将",
  "version": "0.1.0",
  "identifier": "com.seanye.qiangulegends",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "千古名将 Legends of the Ages",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
